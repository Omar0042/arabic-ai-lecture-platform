# Mistral API key — powers Voxtral speech-to-text and chat completions.
# Create one at https://console.mistral.ai/ (API Keys), then either:
#   - copy this file to .env and fill it in, or
#   - export AI_API_KEY in your shell / hosting environment before running.
#
# Note: the app reads AI_API_KEY straight from the environment. A plain .env file
# is NOT auto-loaded by PHP or by the Python script — set the variable in your shell
# (see the README "Setup & run" section for the exact command per OS).
AI_API_KEY=your_mistral_api_key_here
